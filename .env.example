# =============================================
# LianGo - Environment Configuration
# =============================================

APP_NAME=LianGo
APP_VERSION=1.0.0
APP_PORT=8080
APP_ENV=development

# =============================================
# Database Configuration
# DB_DRIVER: postgres | mysql
# =============================================
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=liango_db
DB_SSLMODE=disable

# MySQL (gunakan jika DB_DRIVER=mysql)
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=secret
# DB_NAME=liango_db

# =============================================
# JWT Configuration
# =============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================
# API Security
# =============================================
API_KEY=your-api-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_IPS=127.0.0.1,::1

# =============================================
# Logging
# =============================================
LOG_LEVEL=info
LOG_FILE=storage/logs/app.log
